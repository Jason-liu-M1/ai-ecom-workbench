# =============================================
# AI 电商工作台 - 环境变量配置
# 复制本文件为 .env,然后填入你的 Key
# =============================================

# ===== Provider 选择(留空 = 按 key 自动探测) =====
# 可选: zhipu / siliconflow / deepseek / groq / openai
LLM_PROVIDER=

# ============================================
# 5 种方案,选一个填上 key 即可,其他可以删掉
# ============================================

# ---------- 方案 1: 智谱 GLM-4-Flash(国内直连,永久免费,推荐) ----------
# 申请: https://open.bigmodel.cn  (手机号注册)
# 优势: 文本永久免费,图片 cogview-3 也免费,国内服务器速度飞快
ZHIPU_API_KEY=your_zhipu_api_key_here

# ---------- 方案 2: 硅基流动(国内直连,送 2000 万 tokens) ----------
# 申请: https://cloud.siliconflow.cn/account/ak
# 优势: Qwen2.5-72B 文本质量超好,Kolors 国产免费画图
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# ---------- 方案 3: DeepSeek(国内直连,注册送 $5) ----------
# 申请: https://platform.deepseek.com
# 优势: 深度求索出品,中文写作一流
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ---------- 方案 4: Groq(需科学上网,但免费 + 极速) ----------
# 申请: https://console.groq.com
# 优势: 推理速度全球最快,免费额度大
GROQ_API_KEY=your_groq_api_key_here

# ---------- 方案 5: OpenAI 官方(需翻墙 + 信用卡) ----------
# 申请: https://platform.openai.com/api-keys
# 优势: GPT-4o + DALL·E 3,质量最高
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# 高级: 中转站/反向代理
# ============================================
# 如果你买了中转站(OpenAI 兼容),配 LLM_PROVIDER=openai + OPENAI_BASE_URL
# 例如:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=中转站给你的key
# OPENAI_BASE_URL=https://api.你买的那家.com/v1

# ============================================
# 模型覆盖(不填用各 provider 默认值)
# ============================================
# 智谱:       glm-4-flash / cogview-3
# 硅基流动:    Qwen/Qwen2.5-72B-Instruct / Kwai-Kolors/Kolors
# DeepSeek:   deepseek-chat
# Groq:       llama-3.3-70b-versatile
# OpenAI:     gpt-4o / dall-e-3
GPT_MODEL=
IMAGE_MODEL=

# ============================================
# 服务端口
# ============================================
PORT=8787
